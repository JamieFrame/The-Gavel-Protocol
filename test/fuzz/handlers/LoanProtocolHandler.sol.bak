// SPDX-License-Identifier: MIT
pragma solidity ^0.8.20;

import "forge-std/Test.sol";
import "forge-std/console.sol";
import "../../../contracts/mocks/MockERC20.sol";
import "../../../contracts/LoanProtocol.sol";
import "../../../contracts/PositionNFT.sol";

/**
 * @title LoanProtocolHandler
 * @notice Handler contract for stateful invariant testing
 * @dev Wraps protocol operations to create valid random operation sequences
 * 
 * The handler is responsible for:
 * 1. Calling protocol functions with valid parameters
 * 2. Tracking state for invariant checking
 * 3. Simulating different actors (borrower, lender, etc.)
 * 4. Managing time progression
 * 
 * IMPORTANT: The handler should only call operations that COULD succeed.
 * Expected reverts are fine, but we want to maximize valid state transitions.
 */
contract LoanProtocolHandler is Test {
    
    // ============================================================================
    // STATE
    // ============================================================================
    
    LoanProtocol public protocol;
    PositionNFT public positionNFT;
    MockERC20 public collateralToken;
    MockERC20 public loanToken;
    
    // Test actors
    address[] public actors;
    mapping(address => bool) public isActor;
    
    // Tracking for invariant tests
    uint256[] public auctionIds;
    uint256[] public loanIds;
    mapping(uint256 => bool) public auctionExists;
    mapping(uint256 => bool) public loanExists;
    
    // Ghost variables for tracking
    uint256 public ghost_totalDeposited;
    uint256 public ghost_totalWithdrawn;
    uint256 public ghost_totalBidsPlaced;
    uint256 public ghost_totalLoansCreated;
    uint256 public ghost_totalLoansRepaid;
    uint256 public ghost_totalLoansDefaulted;
    
    // Call counters for coverage tracking
    mapping(bytes4 => uint256) public callCounts;
    
    // ============================================================================
    // CONSTRUCTOR
    // ============================================================================
    
    constructor(
        LoanProtocol _protocol,
        PositionNFT _positionNFT,
        MockERC20 _collateralToken,
        MockERC20 _loanToken,
        address[] memory _actors
    ) {
        protocol = _protocol;
        positionNFT = _positionNFT;
        collateralToken = _collateralToken;
        loanToken = _loanToken;
        
        for (uint i = 0; i < _actors.length; i++) {
            actors.push(_actors[i]);
            isActor[_actors[i]] = true;
        }
    }
    
    // ============================================================================
    // HANDLER FUNCTIONS
    // ============================================================================
    
    /**
     * @notice Deposit collateral for a random actor
     * @param actorSeed Random seed to select actor
     * @param amount Amount to deposit (will be bounded)
     */
    function depositCollateral(uint256 actorSeed, uint256 amount) external {
        callCounts[this.depositCollateral.selector]++;
        
        address actor = _selectActor(actorSeed);
        amount = bound(amount, 1e4, 100e8); // 0.0001 to 100 BTC
        
        // Mint tokens if needed
        uint256 balance = collateralToken.balanceOf(actor);
        if (balance < amount) {
            collateralToken.mint(actor, amount - balance);
        }
        
        vm.startPrank(actor);
        collateralToken.approve(address(protocol), amount);
        
        // Call deposit
        try protocol.depositCollateral(address(collateralToken), amount) {
            ghost_totalDeposited += amount;
        } catch {
            // Expected to fail sometimes (e.g., paused)
        }
        
        vm.stopPrank();
    }
    
    /**
     * @notice Withdraw collateral for a random actor
     * @param actorSeed Random seed to select actor
     * @param amount Amount to withdraw (bounded to available balance)
     */
    function withdrawCollateral(uint256 actorSeed, uint256 amount) external {
        callCounts[this.withdrawCollateral.selector]++;
        
        address actor = _selectActor(actorSeed);
        
        // Get available balance
        uint256 available = protocol.collateralBalances(actor, address(collateralToken));
        if (available == 0) return;
        
        amount = bound(amount, 1, available);
        
        vm.prank(actor);
        try protocol.withdrawCollateral(address(collateralToken), amount) {
            ghost_totalWithdrawn += amount;
        } catch {
            // Expected to fail sometimes
        }
    }
    
    /**
     * @notice Create an auction with random (but valid) parameters
     * @param actorSeed Random seed to select borrower
     * @param collateralAmount Collateral amount (bounded)
     * @param loanAmount Loan amount (bounded)
     * @param maxInterestBps Max interest in basis points (bounded)
     * @param loanDurationDays Loan duration in days (bounded)
     * @param auctionDurationHours Auction duration in hours (bounded)
     */
    function createAuction(
        uint256 actorSeed,
        uint256 collateralAmount,
        uint256 loanAmount,
        uint256 maxInterestBps,
        uint256 loanDurationDays,
        uint256 auctionDurationHours
    ) external {
        callCounts[this.createAuction.selector]++;
        
        address actor = _selectActor(actorSeed);
        
        // Bound parameters to valid ranges
        collateralAmount = bound(collateralAmount, 1e6, 10e8); // 0.01 to 10 BTC
        loanAmount = bound(loanAmount, 1000e6, 1_000_000e6);   // $1K to $1M
        maxInterestBps = bound(maxInterestBps, 100, 5000);     // 1% to 50%
        loanDurationDays = bound(loanDurationDays, 1, 365);    // 1 day to 1 year
        auctionDurationHours = bound(auctionDurationHours, 1, 168); // 1 hour to 1 week
        
        uint256 maxRepayment = loanAmount + (loanAmount * maxInterestBps / 10000);
        uint256 loanDuration = loanDurationDays * 1 days;
        uint256 auctionDuration = auctionDurationHours * 1 hours;
        uint256 bidStep = bound(loanAmount / 1000, 1, loanAmount / 10); // 0.1% to 10% of loan
        
        // Ensure borrower has collateral deposited
        uint256 deposited = protocol.collateralBalances(actor, address(collateralToken));
        if (deposited < collateralAmount) {
            uint256 needed = collateralAmount - deposited;
            collateralToken.mint(actor, needed);
            
            vm.startPrank(actor);
            collateralToken.approve(address(protocol), needed);
            try protocol.depositCollateral(address(collateralToken), needed) {
                ghost_totalDeposited += needed;
            } catch {}
            vm.stopPrank();
        }
        
        vm.prank(actor);
        try protocol.createAuction(
            address(collateralToken),
            collateralAmount,
            address(loanToken),
            loanAmount,
            maxRepayment,
            loanDuration,
            auctionDuration,
            bidStep
        ) returns (uint256 auctionId) {
            auctionIds.push(auctionId);
            auctionExists[auctionId] = true;
        } catch {
            // Expected to fail sometimes (insufficient balance, etc.)
        }
    }
    
    /**
     * @notice Place a bid on a random open auction
     * @param actorSeed Random seed to select lender
     * @param auctionSeed Random seed to select auction
     * @param bidAmount Bid amount (bounded to valid range)
     */
    function placeBid(uint256 actorSeed, uint256 auctionSeed, uint256 bidAmount) external {
        callCounts[this.placeBid.selector]++;
        
        if (auctionIds.length == 0) return;
        
        address lender = _selectActor(actorSeed);
        uint256 auctionId = auctionIds[auctionSeed % auctionIds.length];
        
        // Get auction details
        LoanProtocol.Auction memory auction = protocol.getAuction(auctionId);
        
        if (auction.status != LoanProtocol.AuctionStatus.OPEN) return; // Only bid on OPEN auctions
        
        // Calculate valid bid range
        uint256 maxValidBid;
        if (auction.bidCount == 0) {
            maxValidBid = auction.maxRepayment;
        } else {
            // Must improve by at least bidStep
            if (auction.currentBid <= auction.bidStep) return; // Can't improve
            maxValidBid = auction.currentBid - auction.bidStep;
        }
        uint256 minValidBid = auction.loanAmount;
        
        if (maxValidBid < minValidBid) return; // No valid bid possible
        
        bidAmount = bound(bidAmount, minValidBid, maxValidBid);
        
        // Ensure lender has funds
        uint256 balance = loanToken.balanceOf(lender);
        if (balance < bidAmount) {
            loanToken.mint(lender, bidAmount - balance);
        }
        
        vm.startPrank(lender);
        loanToken.approve(address(protocol), bidAmount);
        
        try protocol.placeBid(auctionId, bidAmount) {
            ghost_totalBidsPlaced++;
        } catch {
            // Expected to fail sometimes (outbid, auction ended, etc.)
        }
        vm.stopPrank();
    }
    
    /**
     * @notice Finalize a random auction that has ended
     * @param auctionSeed Random seed to select auction
     */
    function finalizeAuction(uint256 auctionSeed) external {
        callCounts[this.finalizeAuction.selector]++;
        
        if (auctionIds.length == 0) return;
        
        uint256 auctionId = auctionIds[auctionSeed % auctionIds.length];
        
        try protocol.finalizeAuction(auctionId) {
            loanIds.push(auctionId);
            loanExists[auctionId] = true;
            ghost_totalLoansCreated++;
        } catch {
            // Expected to fail (auction not ended, no bids, already finalized, etc.)
        }
    }
    
    /**
     * @notice Repay a random active loan
     * @param loanSeed Random seed to select loan
     */
    function repayLoan(uint256 loanSeed) external {
        callCounts[this.repayLoan.selector]++;
        
        if (loanIds.length == 0) return;
        
        uint256 loanId = loanIds[loanSeed % loanIds.length];
        
        // Get loan details
        (address borrower,, uint256 collateralAmount,, uint256 loanAmount, 
         uint256 repaymentAmount, uint256 maturityTimestamp,, 
         LoanProtocol.LoanStatus status) = protocol.loans(loanId);
        
        if (status != LoanProtocol.LoanStatus.ACTIVE) return; // Only repay ACTIVE loans
        
        // Ensure borrower has repayment funds
        uint256 balance = loanToken.balanceOf(borrower);
        if (balance < repaymentAmount) {
            loanToken.mint(borrower, repaymentAmount - balance);
        }
        
        vm.startPrank(borrower);
        loanToken.approve(address(protocol), repaymentAmount);
        
        try protocol.repayLoan(loanId) {
            ghost_totalLoansRepaid++;
        } catch {
            // Expected to fail sometimes
        }
        vm.stopPrank();
    }
    
    /**
     * @notice Claim collateral on a defaulted loan
     * @param loanSeed Random seed to select loan
     */
    function claimCollateral(uint256 loanSeed) external {
        callCounts[this.claimCollateral.selector]++;
        
        if (loanIds.length == 0) return;
        
        uint256 loanId = loanIds[loanSeed % loanIds.length];
        
        // Get lender from loan struct
        (,,,,,,, address lender, LoanProtocol.LoanStatus status) = protocol.loans(loanId);
        
        if (status != LoanProtocol.LoanStatus.ACTIVE) return; // Only claim on ACTIVE loans (that have defaulted)
        
        vm.prank(lender);
        try protocol.claimCollateral(loanId) {
            ghost_totalLoansDefaulted++;
        } catch {
            // Expected to fail (loan not defaulted, wrong caller, etc.)
        }
    }
    
    /**
     * @notice Warp time forward (simulate passage of time)
     * @param secondsSeed Random amount of seconds to warp
     */
    function warpTime(uint256 secondsSeed) external {
        callCounts[this.warpTime.selector]++;
        
        // Warp between 1 minute and 30 days
        uint256 secondsToWarp = bound(secondsSeed, 60, 30 days);
        
        vm.warp(block.timestamp + secondsToWarp);
    }
    
    /**
     * @notice Cancel a random auction with no bids
     * @param auctionSeed Random seed to select auction
     */
    function cancelAuction(uint256 auctionSeed) external {
        callCounts[this.cancelAuction.selector]++;
        
        if (auctionIds.length == 0) return;
        
        uint256 auctionId = auctionIds[auctionSeed % auctionIds.length];
        
        // Get auction details
        LoanProtocol.Auction memory auction = protocol.getAuction(auctionId);
        
        if (auction.status != LoanProtocol.AuctionStatus.OPEN || auction.bidCount > 0) return;
        
        vm.prank(auction.borrower);
        try protocol.cancelAuction(auctionId) {
            // Auction cancelled successfully
        } catch {
            // Expected to fail sometimes
        }
    }
    
    // ============================================================================
    // MARKETPLACE HANDLERS
    // ============================================================================
    
    /**
     * @notice List a position on the marketplace
     * @param loanSeed Random seed to select loan
     * @param actorSeed Random seed (for position type selection)
     * @param askingPrice Asking price (bounded)
     */
    function listPosition(uint256 loanSeed, uint256 actorSeed, uint256 askingPrice) external {
        callCounts[this.listPosition.selector]++;
        
        if (loanIds.length == 0) return;
        
        uint256 loanId = loanIds[loanSeed % loanIds.length];
        askingPrice = bound(askingPrice, 100e6, 10_000_000e6); // $100 to $10M
        
        // Get loan details to find borrower/lender
        (address borrower,,,,,,,address lender, LoanProtocol.LoanStatus status) = protocol.loans(loanId);
        
        if (status != LoanProtocol.LoanStatus.ACTIVE) return;
        
        // Randomly select borrower or lender position
        bool isBorrower = actorSeed % 2 == 0;
        string memory positionType = isBorrower ? "borrower" : "lender";
        address owner = isBorrower ? borrower : lender;
        
        vm.prank(owner);
        try protocol.listPosition(loanId, positionType, address(loanToken), askingPrice) {
            // Position listed successfully
        } catch {
            // Expected to fail sometimes (already listed, not owner, etc.)
        }
    }
    
    /**
     * @notice Make an offer on a listed position
     * @param loanSeed Random seed to select loan
     * @param actorSeed Random seed to select buyer
     * @param offerAmount Offer amount (bounded)
     * @param durationHours Offer duration in hours
     */
    function makeOffer(
        uint256 loanSeed, 
        uint256 actorSeed, 
        uint256 offerAmount,
        uint256 durationHours
    ) external {
        callCounts[this.makeOffer.selector]++;
        
        if (loanIds.length == 0) return;
        
        uint256 loanId = loanIds[loanSeed % loanIds.length];
        address buyer = _selectActor(actorSeed);
        offerAmount = bound(offerAmount, 100e6, 1_000_000e6);
        durationHours = bound(durationHours, 1, 168); // 1 hour to 1 week
        
        // Ensure buyer has funds
        uint256 balance = loanToken.balanceOf(buyer);
        if (balance < offerAmount) {
            loanToken.mint(buyer, offerAmount - balance);
        }
        
        vm.startPrank(buyer);
        loanToken.approve(address(protocol), offerAmount);
        
        try protocol.makeMarketplaceOffer(loanId, offerAmount, durationHours * 1 hours) {
            // Offer made successfully
        } catch {
            // Expected to fail sometimes (not listed, insufficient funds, etc.)
        }
        vm.stopPrank();
    }
    
    // ============================================================================
    // HELPER FUNCTIONS
    // ============================================================================
    
    function _selectActor(uint256 seed) internal view returns (address) {
        return actors[seed % actors.length];
    }
    
    // ============================================================================
    // VIEW FUNCTIONS (for invariant tests)
    // ============================================================================
    
    function getAuctionCount() external view returns (uint256) {
        return auctionIds.length;
    }
    
    function getLoanCount() external view returns (uint256) {
        return loanIds.length;
    }
    
    function getActorCount() external view returns (uint256) {
        return actors.length;
    }
    
    function getCallCount(bytes4 selector) external view returns (uint256) {
        return callCounts[selector];
    }
}
